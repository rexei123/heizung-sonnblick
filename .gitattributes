# Auto-detect text files, normalize to LF on check-in
* text=auto

# Explicit LF (for files that run in Linux containers or cross-platform tooling)
*.sh        text eol=lf
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.sql       text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
Dockerfile  text eol=lf
Dockerfile.* text eol=lf
*.Caddyfile text eol=lf
Caddyfile*  text eol=lf
.env.example text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.dockerignore text eol=lf

# Windows-only files: keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# Binary files: no conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.docx      binary
*.xlsx      binary
*.pptx      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.zip       binary
*.gz        binary
*.tar       binary
