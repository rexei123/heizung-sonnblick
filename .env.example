# Diese Datei als Vorlage in .env kopieren: cp .env.example .env

# --- Datenbank ---
POSTGRES_DB=heizung
POSTGRES_USER=heizung
POSTGRES_PASSWORD=heizung_dev
DATABASE_URL=postgresql+asyncpg://heizung:heizung_dev@db:5432/heizung

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Anwendung ---
ENVIRONMENT=development
LOG_LEVEL=INFO
# In Produktion mit z. B. `openssl rand -hex 32` erzeugen:
SECRET_KEY=change-me-in-production

# --- Wetterdaten (Kaprun) ---
OPENMETEO_LATITUDE=47.272
OPENMETEO_LONGITUDE=12.753

# --- LoRaWAN (Sprint 5) ---
# MQTT-Credentials werden in Sprint 5.3 mit mosquitto_passwd erzeugt.
# In .env eintragen, nicht im Repo.
MQTT_HEIZUNG_PASSWORD=changeme
MQTT_CHIRPSTACK_PASSWORD=changeme

# ChirpStack-DB
CHIRPSTACK_DB_PASSWORD=chirpstack

# ChirpStack API-Secret (mind. 32 Zeichen, in Produktion via openssl rand -hex 32)
CHIRPSTACK_API_SECRET=please-change-this-secret-min-32-chars-long

# ChirpStack API-Key fuer Bootstrap-Skript (wird nach erstem Login in der UI generiert)
CHIRPSTACK_API_KEY=
