# Wird auf dem Server unter /opt/heizung-sonnblick/infra/deploy/.env gepflegt.
# NICHT ins Git einchecken.

# Stage: test | main
# Für Main: STAGE=main, PUBLIC_HOSTNAME=heizung.hoteltec.at
STAGE=test
PUBLIC_HOSTNAME=heizung-test.hoteltec.at

# Optional: ueberschreibt das Branch-Mapping in deploy-pull.sh.
# Default: STAGE=test -> develop, STAGE=main -> main.
# Nur setzen, wenn auf einen abweichenden Branch deployed werden soll
# (z.B. fuer Hotfix-Tests). Leer lassen im Normalbetrieb.
# DEPLOY_BRANCH=

# Optional: ueberschreibt das Image-Tag, das aus GHCR gepullt wird.
# Default: :develop. Wert :main fuer Main-Stage, oder :develop-<sha7>
# fuer SHA-Pinning (siehe Backlog H-6).
# IMAGE_TAG=develop

# Datenbank
POSTGRES_DB=heizung
POSTGRES_USER=heizung
POSTGRES_PASSWORD=__bitte-aendern__

# Anwendung
ENVIRONMENT=production
SECRET_KEY=__mind-32-zeichen-secret__
DATABASE_URL=postgresql+asyncpg://heizung:__bitte-aendern__@db:5432/heizung
REDIS_URL=redis://redis:6379/0

# Wetter (Open-Meteo, kein API-Key nötig)
OPENMETEO_LATITUDE=47.272
OPENMETEO_LONGITUDE=12.753

# LoRaWAN (Sprint 6 — nur Test-Server)
# CHIRPSTACK_HOSTNAME nur auf STAGE=test setzen, auf main leer lassen.
CHIRPSTACK_HOSTNAME=cs-test.hoteltec.at

# bcrypt-Hash für Caddy-Basic-Auth, generiert mit:
#   docker run --rm caddy:2 caddy hash-password --plaintext "<passwort>"
# WICHTIG: Doppelte Dollarzeichen ($$) für jedes einzelne $ im Hash, weil Compose
# Variable-Interpolation macht. Hash hat typisch 4 $-Zeichen -> 8 in der .env.
CHIRPSTACK_BASIC_AUTH_HASH=__bcrypt-hash-mit-doppelten-dollarzeichen__

# K-1 (Sprint 8a): Basic-Auth-Hash fuer /api/* + /openapi.json + /docs +
# /redoc auf der Heizungs-Site. Selbes Hash-Format wie CHIRPSTACK_BASIC_
# AUTH_HASH (bcrypt + doppelte Dollarzeichen). User ist hardcoded `hotel`
# im Caddyfile. Setup-Anleitung: RUNBOOK §10b.
HOTEL_BASIC_AUTH_HASH=__bcrypt-hash-mit-doppelten-dollarzeichen__

# ChirpStack-DB
CHIRPSTACK_DB_PASSWORD=__bitte-aendern__

# ChirpStack API-Secret (mind. 32 Zeichen, mit `openssl rand -hex 32` erzeugen)
CHIRPSTACK_API_SECRET=__mind-32-zeichen-secret__

# Mosquitto MQTT-Auth (passwd + ACL aktiv, Sprint 6.6.4).
# Drei User. Passwoerter mind. 32 Zeichen, openssl rand -hex 32.
# passwd-Datei wird daraus auf dem Server generiert (siehe RUNBOOK).
MQTT_CHIRPSTACK_PASSWORD=__mind-32-zeichen-secret__
MQTT_GATEWAY_UG65_PASSWORD=__mind-32-zeichen-secret__
MQTT_HEIZUNG_PASSWORD=__mind-32-zeichen-secret__

# Optional: ChirpStack-Gateway-Bridge (Basic-Station-Mode, derzeit nicht
# aktiv genutzt — UG65 laeuft im ChirpStack-v4-Direktmodus). Wenn
# Basic-Station-Gateways spaeter dazukommen: gateway-bridge nutzt den
# chirpstack-User. Diese Vars dann auf MQTT_CHIRPSTACK_* setzen.
MQTT_GATEWAY_BRIDGE_USER=chirpstack
MQTT_GATEWAY_BRIDGE_PASSWORD=${MQTT_CHIRPSTACK_PASSWORD}
