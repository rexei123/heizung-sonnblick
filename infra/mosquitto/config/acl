# MQTT ACL für LoRaWAN-Pipeline
# Format: https://mosquitto.org/man/mosquitto-conf-5.html

# ChirpStack: darf alles unter application/* publishen + lesen
user chirpstack
topic readwrite application/#
topic readwrite gateway/#
topic readwrite eu868/#

# heizung-api: darf Uplinks lesen, Downlinks schreiben
user heizung-api
topic read application/+/device/+/event/up
topic read application/+/device/+/event/join
topic read application/+/device/+/event/status
topic read application/+/device/+/event/ack
topic write application/+/device/+/command/down
