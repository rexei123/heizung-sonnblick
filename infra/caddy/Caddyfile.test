# Caddy-Konfiguration für Test-Umgebung
# Hostname wird per Env-Variable PUBLIC_HOSTNAME aus .env gezogen.
# Produktivbetrieb: heizung-test.hoteltec.at (seit Sprint 4, 2026-04-22)
# Sprint 6 (2026-04-28): zusätzliche Site cs-test.hoteltec.at für ChirpStack-UI
# mit Basic-Auth (CHIRPSTACK_BASIC_AUTH_HASH, bcrypt).
# Let's Encrypt wird automatisch gezogen.

{
    email hotelsonnblick@gmail.com
    # Staging-ACME lässt sich bei Bedarf hier einschalten:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# --- Heizungs-Frontend + API ---
{$PUBLIC_HOSTNAME} {
    encode zstd gzip

    # API unter /api und /openapi.json
    @api {
        path /api/* /openapi.json /docs /redoc /health
    }
    handle @api {
        reverse_proxy api:8000
    }

    # Alles andere → Next.js
    reverse_proxy web:3000

    # Security-Header
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/test.access.log {
            roll_size 50mb
            roll_keep 10
        }
        format json
    }
}

# --- ChirpStack-UI + Gateway-Bridge (nur Test-Stage, Sprint 6) ---
# Auth UI: ChirpStack-eigenes Login-Formular (admin/<starkes-pw>).
# Auth Gateway: Basic-Station-Authentication via Bridge-Konfig (DevEUI-Match).
# /router-info + /router-data sind Basic-Station-WebSocket-Endpoints fuer das UG65.
{$CHIRPSTACK_HOSTNAME} {
    encode zstd gzip

    # Basic-Station WebSocket-Routen zum gateway-bridge
    @basic_station {
        path /router* /api/gateway*
    }
    handle @basic_station {
        reverse_proxy chirpstack-gateway-bridge:3001
    }

    # Default: ChirpStack-UI
    reverse_proxy chirpstack:8080

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/cs-test.access.log {
            roll_size 50mb
            roll_keep 10
        }
        format json
    }
}
