# Caddy-Konfiguration für Test-Umgebung
# Hostname wird per Env-Variable PUBLIC_HOSTNAME aus .env gezogen.
# Produktivbetrieb: heizung-test.hoteltec.at (seit Sprint 4, 2026-04-22)
# Sprint 6 (2026-04-28): zusätzliche Site cs-test.hoteltec.at für ChirpStack-UI
# mit Basic-Auth (CHIRPSTACK_BASIC_AUTH_HASH, bcrypt).
# Let's Encrypt wird automatisch gezogen.

{
    email hotelsonnblick@gmail.com
    # Staging-ACME lässt sich bei Bedarf hier einschalten:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# --- Heizungs-Frontend + API ---
{$PUBLIC_HOSTNAME} {
    encode zstd gzip

    # Auth-Architektur Stand 2026-05-15 (Sprint 10-Prep):
    # - /health + /healthz: public (Monitoring)
    # - /openapi.json + /docs + /redoc: Caddy-Basic-Auth (Reconnaissance-Schutz,
    #   FastAPI hat kein eigenes Auth-Layer dort)
    # - /api/*: Backend-Auth via JWT-Cookie (Sprint 9.17a/b, AE-50)
    # - Frontend: Backend-Auth via JWT-Cookie (Login-Page ist Public)
    #
    # Vorher (Sprint 8a, K-1): Site-weite Basic-Auth weil Backend ungeschützt war.
    # Aufgelöst nach AE-50-Implementierung in Sprint 9.17.
    route {
        # 1. Public: Backend-Liveness /health (Uptime-Monitoring)
        @backend_health path /health
        handle @backend_health {
            reverse_proxy api:8000
        }

        # 2. Public: Frontend-Liveness /healthz (Docker-HEALTHCHECK)
        @frontend_health path /healthz
        handle @frontend_health {
            reverse_proxy web:3000
        }

        # 3. API-Doku bleibt Caddy-Basic-Auth-geschützt
        # Sprint-10-Prep (2026-05-15): FastAPI hat kein eigenes Auth-Layer
        # auf /openapi.json /docs /redoc. Caddy-Schicht erhält
        # Reconnaissance-Schutz. Backend-Endpoints (/api/*) haben
        # eigenes Auth via JWT-Cookie (Sprint 9.17a/b, AE-50).
        @api_docs path /openapi.json /docs /docs/* /redoc /redoc/*
        handle @api_docs {
            basicauth {
                hotel {$HOTEL_BASIC_AUTH_HASH}
            }
            reverse_proxy api:8000
        }

        # 4. API-Endpoints: Backend-Auth übernimmt
        # Sprint 9.17a hat 17 GETs + alle mutierenden Endpoints mit
        # require_user / require_admin / require_real_user abgesichert.
        # Sprint 9.17b hat Logout-Cookie-Invalidation gefixt.
        @api path /api/*
        handle @api {
            reverse_proxy api:8000
        }

        # 5. Frontend: Backend-Auth schützt über JWT-Cookie
        # Login-Page (/login, /auth/*) selbst ist Public.
        reverse_proxy web:3000
    }

    # Security-Header
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/test.access.log {
            roll_size 50mb
            roll_keep 10
        }
        format json
    }
}

# --- ChirpStack-UI + Gateway-Bridge (nur Test-Stage, Sprint 6) ---
# Auth UI: ChirpStack-eigenes Login-Formular (admin/<starkes-pw>).
# Auth Gateway: Basic-Station-Authentication via Bridge-Konfig (DevEUI-Match).
# /router-info + /router-data sind Basic-Station-WebSocket-Endpoints fuer das UG65.
{$CHIRPSTACK_HOSTNAME} {
    encode zstd gzip

    # Basic-Station WebSocket-Routen zum gateway-bridge
    @basic_station {
        path /router* /api/gateway*
    }
    handle @basic_station {
        reverse_proxy chirpstack-gateway-bridge:3001
    }

    # Default: ChirpStack-UI
    reverse_proxy chirpstack:8080

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/cs-test.access.log {
            roll_size 50mb
            roll_keep 10
        }
        format json
    }
}
